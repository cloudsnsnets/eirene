# EIRENE — Environment Configuration
# Cloud SNS Pty Ltd
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# ── JWT Secret ────────────────────────────────────────────────────────────────
# Shared between voice-auth and proxy services.
# Generate a strong random secret:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-strong-random-secret

# ── Voice Authentication ──────────────────────────────────────────────────────
# Similarity threshold for voice matching (0.0 to 1.0)
# Higher = stricter. 0.75 is recommended.
SIMILARITY_THRESHOLD=0.75

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
# Get your tunnel token from:
# https://one.dash.cloudflare.com/
# Zero Trust → Networks → Tunnels → Create tunnel → Copy token
CLOUDFLARE_TUNNEL_TOKEN=not-set

# ── Tunnel Hopper ─────────────────────────────────────────────────────────────
# Cloudflare API token (needs Tunnel Write + Zone Read permissions)
# Create at: https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=not-set

# Zone ID for your domain (found on domain overview page, right sidebar)
CF_ZONE_ID=not-set

# Your tunnel ID (from Zero Trust → Networks → Tunnels)
CF_TUNNEL_ID=not-set

# Your Eirene PWA domain
DOMAIN=eirene.yourdomain.com


# Enrollment secret — required for voice enrollment
# Generate: openssl rand -hex 32
ENROLL_SECRET=not-set
